	6. Rule layer
6.1 Base rule interface
from abc import ABC, abstractmethod

class BaseRule(ABC):
    @abstractmethod
    def apply(self, input_symbol: str) -> str:
        raise NotImplementedError
		
	6.2 ShiftRule
	class ShiftRule(BaseRule):
    def __init__(self, alphabet: list[str], shift: int) -> None:
        self.alphabet = alphabet
        self.shift = shift
        self.index = {symbol: i for i, symbol in enumerate(alphabet)}

    def apply(self, input_symbol: str) -> str:
        pos = self.index[input_symbol]
        new_pos = (pos + self.shift) % len(self.alphabet)
        return self.alphabet[new_pos]
		
